{
  "$schema": "https://raw.githubusercontent.com/nicegui/tauri/feat/json-schema-generator/core/tauri-config-schema/schema.json",
  "productName": "PNG Layout Tool",
  "version": "1.1.0",
  "identifier": "com.pnglayout.tool",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist/renderer"
  },
  "app": {
    "windows": [
      {
        "title": "PNG 透明图片自动排版工具",
        "width": 1400,
        "height": 900,
        "minWidth": 1000,
        "minHeight": 700,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' blob: data:; style-src 'self' 'unsafe-inline'; script-src 'self'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "signingIdentity": "-"
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDkzRDlBNzE5OTE1Qzg5MTEKUldRUmlWeVJHYWZaazloV0VoUUxMMlZWaS9rOHNESklSSlgrRUhtL1F2RnlNN0lQZ21qVkVDSGkK",
      "endpoints": [
        "https://github.com/PNGTRID/png-layout-tool/releases/latest/download/latest.json"
      ]
    }
  }
}
